    <!-- Venue card -->
    <div class="relative overflow-hidden rounded-3xl border border-white/5 bg-surface-card">
      <!-- Decorative map-like bg -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-neon-purple/5"></div>

