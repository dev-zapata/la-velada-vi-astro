---
const navLinks = [
  { href: "#combates", label: "Combates" },
  { href: "#sede", label: "Sede" },
  { href: "#entradas", label: "Entradas" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between md:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div
          class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary font-heading text-lg font-bold text-black transition-transform group-hover:scale-110"
        >
          VI
        </div>
        <span
          class="hidden font-heading text-lg font-semibold tracking-wider text-white uppercase sm:block"
        >
          La Velada
        </span>
      </a>

      <div class="hidden items-center gap-8 md:flex">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="font-medium text-sm uppercase tracking-widest text-gray-300 transition-colors hover:text-primary"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <a
        href="#entradas"
        class="rounded-full bg-primary px-5 py-2 font-heading text-sm font-semibold tracking-wider text-black uppercase transition-all hover:bg-primary-light hover:shadow-[0_0_20px_rgba(245,158,11,0.4)]"
      >
        Consigue tu entrada
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  let lastScroll = 0;

  window.addEventListener("scroll", () => {
    if (!navbar) return;
    const currentScroll = window.scrollY;

    if (currentScroll > 80) {
      navbar.style.backgroundColor = "rgba(10, 10, 15, 0.9)";
      navbar.style.backdropFilter = "blur(12px)";
      navbar.style.borderBottom = "1px solid rgba(245, 158, 11, 0.1)";
    } else {
      navbar.style.backgroundColor = "transparent";
      navbar.style.backdropFilter = "none";
      navbar.style.borderBottom = "none";
    }

    lastScroll = currentScroll;
  });
</script>
