---
const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-white/5 bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary font-heading text-lg font-bold text-black">
            VI
          </div>
          <span class="font-heading text-lg font-semibold tracking-wider text-white uppercase">
            La Velada del Año
          </span>
        </div>
        <p class="text-sm text-gray-500 max-w-xs">
          El evento de boxeo más grande del streaming en español. Una noche inolvidable de combates y música.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-heading text-sm font-semibold uppercase tracking-widest text-white mb-4">Evento</h4>
        <ul class="space-y-2">
          <li><a href="#combates" class="text-sm text-gray-500 hover:text-primary transition-colors">Combates</a></li>
          <li><a href="#sede" class="text-sm text-gray-500 hover:text-primary transition-colors">Sede</a></li>
          <li><a href="#entradas" class="text-sm text-gray-500 hover:text-primary transition-colors">Entradas</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-heading text-sm font-semibold uppercase tracking-widest text-white mb-4">Síguenos</h4>
        <div class="flex gap-4">
          <a href="#" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-primary/20 hover:text-primary" aria-label="Twitch">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
          </a>
          <a href="#" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-primary/20 hover:text-primary" aria-label="YouTube">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="#" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-primary/20 hover:text-primary" aria-label="X/Twitter">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
