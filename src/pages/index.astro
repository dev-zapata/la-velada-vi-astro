---

<Layout title="La Velada del A\u00f1o VI | El evento de boxeo m\u00e1s grande del streaming">
  <Navbar />
  <main>
    <Hero />

    <!-- Combates Section -->
    <section id="combates" class="relative pt-10 pb-24 sm:pt-16 sm:pb-32">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center mb-16">
          <span class="text-xs font-medium uppercase tracking-[0.3em] text-primary">La cartelera</span>
          <h2 class="mt-4 font-heading text-4xl sm:text-5xl md:text-6xl font-bold uppercase text-white">
            Los <span class="text-gradient">combates</span>
          </h2>
          <p class="mt-4 text-gray-400 max-w-xl mx-auto">
            10 peleas que van a romper internet. Streamers, creadores y leyendas del contenido se suben al ring.
          </p>
        </div>

        <!-- Fight cards grid -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {fights.map((fight) => <FightCard {...fight} />)}
        </div>

        <!-- Total fights -->
        <div class="mt-12 text-center">
          <p class="text-sm text-gray-500">
            <span class="text-primary font-medium">10 combates confirmados</span> — La noche más épica del streaming.
          </p>
        </div>
      </div>
    </section>

    <Venue />
    <Tickets />
  </main>
  <Footer />
</Layout>
